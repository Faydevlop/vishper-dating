{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "androind": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "android:device": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android-device.ps1",
    "androind:device": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android-device.ps1",
    "android:usb": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android-device.ps1",
    "android:apk:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release-apk.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "assets:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/generate-assets.ps1"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.6",
    "expo-blur": "~15.0.7",
    "expo-constants": "^55.0.14",
    "expo-font": "~55.0.4",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "run": "file:./tooling/run"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
